/vendor/
/node_modules/
composer.lock
.phpunit.result.cache
.idea/
.DS_Store

# Build artifacts in resources/dist ARE committed so consuming sites get prebuilt
# assets without running npm. Only the Vite hot file is transient.
resources/dist/hot

# Never commit private keys / certificate material
*.key
*.pem
*.pfx
*.p12
deploy/terraform/.terraform/
deploy/terraform/*.tfstate
deploy/terraform/*.tfstate.*
deploy/terraform/*.tfvars
!deploy/terraform/*.tfvars.example
